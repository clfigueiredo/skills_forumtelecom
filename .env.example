# Fórum Telecom Skills — Variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# IMPORTANTE: nunca commite o .env real

# =============================================================================
# MikroTik
# =============================================================================
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PORT=22
MIKROTIK_API_PORT=443
MIKROTIK_API_PASS=

# =============================================================================
# Cisco
# =============================================================================
CISCO_HOST=10.0.0.1
CISCO_USER=admin
CISCO_PORT=22

# =============================================================================
# Huawei NE (NE40E, NE8000, ME60)
# =============================================================================
HUAWEI_HOST=10.0.0.2
HUAWEI_USER=admin
HUAWEI_PORT=22

# =============================================================================
# OLT FiberHome (AN5516, AN5116, AN6000)
# =============================================================================
FH_OLT_HOST=10.0.1.10
FH_OLT_USER=GEPON
FH_OLT_PASS=GEPON

# =============================================================================
# OLT Huawei (MA5800, MA5680T, EA5800)
# =============================================================================
HW_OLT_HOST=10.0.1.20
HW_OLT_USER=root
HW_OLT_PASS=admin

# =============================================================================
# Proxmox VE
# =============================================================================
PVE_HOST=pve.example.com
PVE_TOKEN=PVEAPIToken=user@pve!tokenid=00000000-0000-0000-0000-000000000000

# =============================================================================
# Docker (local socket OU SSH remoto OU TCP)
# =============================================================================
DOCKER_HOST=unix:///var/run/docker.sock
# DOCKER_HOST=ssh://user@10.0.0.10
# DOCKER_HOST=tcp://docker.example.com:2376

# =============================================================================
# Zabbix
# =============================================================================
ZABBIX_URL=https://zabbix.example.com/api_jsonrpc.php
ZABBIX_TOKEN=

# =============================================================================
# Anthropic (para uso com Claude Agent SDK)
# =============================================================================
ANTHROPIC_API_KEY=
